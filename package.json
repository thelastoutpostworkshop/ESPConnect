{
  "name": "espconnect",
  "productName": "ESPConnect",
  "private": true,
  "version": "1.1.13",
  "type": "module",
  "description": "Browser-based control center for ESP32 and ESP8266 boards",
  "main": "electron/main.cjs",
  "author": "The Last Outpost Workshop",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:fatfs": "vitest run src/tests/fatfs.fixture.test.ts",
    "test:e2e": "playwright test",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "electron-squirrel-startup": "^1.0.1",
    "tasmota-webserial-esptool": "^7.3.7",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vuetify": "^4.0.6"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.5.0",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
